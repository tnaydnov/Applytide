    stats = await service.get_email_stats()
    
    return EmailStatsResponse(
        smtp_configured=stats.smtp_configured,
        smtp_host=stats.smtp_host,
        smtp_port=stats.smtp_port,
        from_email=stats.from_email,
        last_test_sent_at=stats.last_test_sent_at,
