    )


@router.get(
    "/email/activity",
    summary="Get Email Activity"
)
@limiter.limit("30/minute")
async def get_email_activity(
    request: Request,
    days: int = Query(default=7, ge=1, le=90),
    db: Session = Depends(get_db),
    current_admin: models.User = Depends(get_admin_user)
):
    """
    Get email-related activity from audit logs
    
    Returns test email statistics for the specified time period
    """
    service = EmailAdminService(db)
    activity = await service.get_email_activity(days=days)
    
    return {
        "test_emails_sent": activity["test_emails_sent"],
        "test_emails_failed": activity["test_emails_failed"],
        "total_attempts": activity["total_attempts"],
        "success_rate": activity["success_rate"],
        "days": days
    }


@router.post(
    "/email/test",
    summary="Send Test Email"
)
@limiter.limit("10/hour")  # Strict limit for test emails
async def send_test_email(
    request: Request,
    test_request: SendTestEmailRequest,
    db: Session = Depends(get_db),
    current_admin: models.User = Depends(get_admin_user_with_step_up)
):
    """
    Send a test email
    
    - Requires step-up authentication
    - Rate limited to 10 per hour
    - All test emails are audit logged
    """
    service = EmailAdminService(db)
    
    success = await service.send_test_email(
        to_email=test_request.to_email,
        subject=test_request.subject,
        message=test_request.message,
        admin_id=current_admin.id,
        justification=test_request.justification
    )
    
    if success:
        return {
            "success": True,
            "message": f"Test email sent to {test_request.to_email}"
        }
    else:
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail="Failed to send test email. Check SMTP configuration."
        )


