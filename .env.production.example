# Production Environment Configuration
# Copy this file to .env.production and fill in the values

# Environment
ENVIRONMENT=production

# Database Configuration
DATABASE_URL=postgresql+psycopg2://applytide_user:YOUR_DB_PASSWORD@pg:5432/applytide_prod
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD

# Redis Configuration  
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=YOUR_SECURE_REDIS_PASSWORD

# JWT Secrets (CRITICAL: Generate secure random strings)
# Run: python -c "import secrets; print('JWT_SECRET=' + secrets.token_urlsafe(32)); print('REFRESH_SECRET=' + secrets.token_urlsafe(32))"
JWT_SECRET=YOUR_SECURE_JWT_SECRET_32_CHARS_MINIMUM
REFRESH_SECRET=YOUR_SECURE_REFRESH_SECRET_32_CHARS_MINIMUM

# URLs
FRONTEND_URL=https://applytide.com
APP_BASE_URL=https://applytide.com

# Security Settings
SECURE_COOKIES=true
SAME_SITE_COOKIES=lax
ALLOWED_ORIGINS=https://applytide.com,https://www.applytide.com
ALLOWED_HOSTS=applytide.com,www.applytide.com

# Email Configuration (Production SMTP)
SMTP_HOST=YOUR_SMTP_HOST
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_USERNAME
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
FROM_EMAIL=noreply@applytide.com
SMTP_FROM=noreply@applytide.com

# Contact Emails
CONTACT_EMAIL=contact@applytide.com
SUPPORT_EMAIL=support@applytide.com
BILLING_EMAIL=billing@applytide.com
ADMIN_EMAIL=admin@applytide.com

# OpenAI Configuration
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Google OAuth Configuration
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://applytide.com/api/auth/google/callback

# Rate Limiting (adjust based on expected load)
GLOBAL_RATE_LIMIT_REQUESTS=5000
GLOBAL_RATE_LIMIT_WINDOW=3600

# Token Expiration (production values)
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=7

# Logging
SECURITY_LOG_FILE=/app/logs/security.log

# Next.js Frontend Environment Variables
NEXT_PUBLIC_API_BASE=https://applytide.com/api
NEXT_PUBLIC_APP_URL=https://applytide.com