# Production Environment Variables - CHANGE THESE IN PRODUCTION!

# JWT Security - Generate strong secrets for production
JWT_SECRET=your-super-secret-jwt-key-minimum-256-bits-change-this-in-production
REFRESH_SECRET=your-different-super-secret-refresh-key-minimum-256-bits-change-this

# Token Lifetimes (Production Recommendations)
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=7

# Database Security
DATABASE_URL=postgresql+psycopg2://secure_user:strong_password@localhost:5432/applytide_prod

# CORS Security (Production URLs only)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email Security
SMTP_HOST=smtp.mailgun.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=noreply@yourdomain.com

# Application URLs (HTTPS only)
FRONTEND_URL=https://yourdomain.com
APP_BASE_URL=https://yourdomain.com

# Security Headers
ENVIRONMENT=production
SECURE_COOKIES=true
SAME_SITE_COOKIES=strict

# Rate Limiting
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT=5
REFRESH_RATE_LIMIT=10
