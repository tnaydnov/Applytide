{
  "manifest_version": 3,
  "name": "Applytide – Job Clipper",
  "version": "1.0.4",
  "description": "Extract job details from (almost) any site and save to Applytide.",
  
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  
  "action": {
    "default_title": "Save job to Applytide"
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["job-extractor.js"],
      "css": ["applytide-button.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  
  "commands": {
    "applytide:set-token": {
      "suggested_key": { "default": "Alt+Shift+A" },
      "description": "Set Applytide API token"
    }
  },
  
  "web_accessible_resources": [
    {
      "resources": [
        "*.css",
        "assets/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
