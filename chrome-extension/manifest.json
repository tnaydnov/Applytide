{
  "manifest_version": 3,
  "name": "Applytide",
  "version": "1.3.0",
  "description": "Extract and save job listings to your Applytide account. Automatically parse job details from any website.",
  "icons": {
    "16": "logomark.png",
    "48": "logomark.png",
    "128": "logomark.png"
  },
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "permissions": ["activeTab", "scripting", "tabs", "alarms", "windows"],
  "host_permissions": [
    "https://applytide.com/*",
    "http://localhost/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Applytide", "default_popup": "popup.html", "default_icon": "logomark.png" }
}
