{
  "manifest_version": 3,
  "name": "Applytide",
  "version": "1.1.0",
  "description": "Save jobs to Applytide.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "alarms", "windows"],
  "host_permissions": [
    "https://applytide.com/*",
    "http://localhost/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Applytide", "default_popup": "popup.html" },

  "content_scripts": [
    {
      "matches": ["https://applytide.com/*", "http://localhost/*"],
      "js": ["site-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
